# Application environment: development | production | test
NODE_ENV=development

# Port the HTTP/GraphQL server listens on
PORT=3000

# PostgreSQL connection string (Prisma datasource).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://workbook:workbook@localhost:5432/workbook?schema=public

# Comma-separated list of allowed CORS origins (frontend URLs).
# Example: http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173

# Expose the GraphQL playground / introspection (true|false).
# Keep this false in production.
GRAPHQL_PLAYGROUND=true

# Rate limiting: time window in milliseconds and max requests per window.
# The default bucket applies to the whole surface (GraphQL queries/mutations, REST).
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120

# Stricter, dedicated rate limit for the binary upload endpoint only.
UPLOAD_RATE_LIMIT_TTL_MS=60000
UPLOAD_RATE_LIMIT_MAX=20

# Directory where uploaded file binaries are stored (server-confined root).
UPLOADS_DIR=./uploads

# Maximum allowed upload size in bytes (default 10 MiB).
MAX_UPLOAD_SIZE_BYTES=10485760

# Comma-separated allowlist of accepted upload MIME types (images + PDF only).
ALLOWED_MIME_TYPES=image/png,image/jpeg,image/gif,image/webp,application/pdf

# Public base URL the API is reachable at (no trailing slash). Used to build
# absolute served URLs for uploaded files. In production set this to the
# deployed origin, e.g. https://workbook-api.onrender.com
PUBLIC_BASE_URL=http://localhost:3000

# URL path prefix under which uploaded binaries are served statically.
UPLOADS_PUBLIC_PATH=/uploads

# Consumed by the Docker entrypoint only (not the app): when 'true', the
# container seeds demo data on startup after applying migrations. Idempotent.
# Keep this 'false' in production so demo data is never written to a real DB.
SEED_ON_STARTUP=true
