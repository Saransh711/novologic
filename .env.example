# Application environment: development | production | test
NODE_ENV=development

# Port the HTTP/GraphQL server listens on
PORT=3000

# PostgreSQL connection string (Prisma datasource).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://workbook:workbook@localhost:5432/workbook?schema=public

# Comma-separated list of allowed CORS origins (frontend URLs).
# Example: http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173

# Expose the GraphQL playground / introspection (true|false).
# Keep this false in production.
GRAPHQL_PLAYGROUND=true

# Rate limiting: time window in milliseconds and max requests per window.
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
